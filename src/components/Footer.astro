---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
const base = lang === 'fr' ? '' : '/en';
---

<footer class="border-t border-slate-800 bg-slate-950 px-6 py-12 sm:px-10">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-12 lg:grid-cols-4">
      <div class="col-span-2">
        <div class="flex items-center gap-4 mb-6">
          <img src="/nz-logo-blanc.png" alt="NZ IT Services Logo" class="h-8 w-auto">
          <span class="text-xl font-bold tracking-widest text-white">NZ IT SERVICES</span>
        </div>
        <p class="max-w-md text-slate-400 leading-7">
          {t('footer.description')}
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-amber-400 mb-6">{t('footer.quickLinks')}</h3>
        <ul class="space-y-4">
          <li><a href={`${base}/`} class="text-slate-400 hover:text-white transition-colors">{t('nav.home')}</a></li>
          <li><a href={`${base}/about`} class="text-slate-400 hover:text-white transition-colors">{t('nav.about')}</a></li>
          <li><a href={`${base}/services`} class="text-slate-400 hover:text-white transition-colors">{t('nav.services')}</a></li>
          <li><a href={`${base}/careers`} class="text-slate-400 hover:text-white transition-colors">{t('nav.careers')}</a></li>
          <li><a href={`${base}/contact`} class="text-slate-400 hover:text-white transition-colors">{t('nav.contact')}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-amber-400 mb-6">{t('footer.contact')}</h3>
        <ul class="space-y-4 text-slate-400">
          <li>Paris, France</li>
          <li>Oran, Algérie</li>
          <li>+33 7 53 90 85 70</li>
          <li>contact@nz-services.fr</li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-slate-900 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-slate-500">
        &copy; {currentYear} NZ IT Services. {t('footer.rights')}
      </p>
      <p class="text-xs text-slate-600">
        SIRET 93878550800012 - {t('footer.legal')}
      </p>
    </div>
  </div>
</footer>

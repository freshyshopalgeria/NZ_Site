---
import Layout from "../../layouts/Layout.astro";
import jobs from "../../data/jobs.json";

export function getStaticPaths() {
  return jobs.map((job) => ({
    params: { id: job.id },
    props: { job },
  }));
}

const { job } = Astro.props;
---

<Layout title={`${job.title} - Carrières - NZ IT Services`}>
  <main class="relative overflow-hidden">
    <section class="relative px-6 py-24 sm:px-10 lg:px-14">
      <div class="mx-auto max-w-4xl">
        <a href="/careers" class="inline-flex items-center gap-2 text-amber-400 font-bold mb-12 hover:gap-4 transition-all">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Retour aux offres
        </a>

        <div class="mb-16">
            <div class="flex gap-4 mb-6">
                <span class="inline-flex rounded-full bg-amber-400/10 px-4 py-1 text-xs font-bold text-amber-400">{job.type} · {job.location}</span>
                <span class="inline-flex rounded-full bg-cyan-400/10 px-4 py-1 text-xs font-bold text-cyan-400">{job.experience}</span>
            </div>
            <h1 class="text-5xl font-black text-white mb-8 sm:text-6xl">{job.title}</h1>
            <p class="text-xl text-slate-400 leading-relaxed">{job.description}</p>
        </div>

        <div class="grid gap-12 lg:grid-cols-[1.5fr_1fr]">
            <div class="space-y-12">
                <div class="rounded-[2.5rem] border border-white/5 bg-slate-900/50 p-10">
                    <h2 class="text-2xl font-bold text-white mb-6">Vos Missions</h2>
                    <ul class="space-y-4">
                        {job.missions.map((mission: string) => (
                            <li class="flex gap-4 text-slate-400 leading-7">
                                <div class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-amber-400"></div>
                                {mission}
                            </li>
                        ))}
                    </ul>
                </div>

                <div class="rounded-[2.5rem] border border-white/5 bg-slate-900/50 p-10">
                    <h2 class="text-2xl font-bold text-white mb-6">Votre Profil</h2>
                    <ul class="space-y-4">
                        {job.profile.map((item: string) => (
                            <li class="flex gap-4 text-slate-400 leading-7">
                                <div class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-400"></div>
                                {item}
                            </li>
                        ))}
                    </ul>
                </div>
            </div>

            <aside>
                <div class="sticky top-32">
                    <div class="rounded-[2.5rem] border border-white/10 bg-white p-10 text-center shadow-2xl">
                        <h3 class="text-2xl font-black text-slate-950 mb-4">Postuler à cette offre</h3>
                        <p class="text-slate-600 mb-8 text-sm">Prêt à relever le défi ? Envoyez-nous votre candidature en quelques clics.</p>
                        <a href={`/contact?subject=Candidature ${job.title}`} class="block w-full rounded-2xl bg-amber-500 py-5 text-lg font-black text-slate-950 hover:bg-amber-400 transition-all shadow-xl shadow-amber-500/20">
                            Envoyer mon CV
                        </a>
                    </div>
                    
                    <div class="mt-8 rounded-[2.5rem] border border-white/5 bg-slate-900/30 p-10">
                        <h4 class="text-white font-bold mb-4 italic">"Une structure pensée par des consultants, pour des consultants."</h4>
                        <p class="text-slate-500 text-sm">— F. AIT ALI BRAHAM, CEO</p>
                    </div>
                </div>
            </aside>
        </div>
      </div>
    </section>
  </main>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="About Us - NZ IT Services">
  <main class="relative overflow-hidden">
    <section class="relative px-6 py-24 sm:px-10 lg:px-14">
      <div class="mx-auto max-w-5xl">
        <div class="mb-20 text-center animate-fade-in-up">
          <p class="text-sm font-bold uppercase tracking-[0.3em] text-amber-400">OUR STORY</p>
          <h1 class="mt-6 text-6xl font-black text-white sm:text-7xl">One Ambition: SAP Excellence</h1>
        </div>

        <div class="grid gap-16 lg:grid-cols-2 lg:items-center mb-24">
            <div class="animate-fade-in-left">
                <h2 class="text-3xl font-bold text-white mb-8">The Genesis of an Expertise-Driven Project</h2>
                <div class="space-y-6 text-lg text-slate-400 leading-relaxed">
                    <p>
                        NZ IT Services is born from a deep conviction: nearshore delivery must reach the same heights of exigency as the best European IT consultancies.
                    </p>
                    <p>
                        Founded by a seasoned SAP consultant (8+ years of experience on critical projects in France), NZ was built brick by brick on values of transparency, technicality, and stability.
                    </p>
                    <p>
                        Our presence in Oran is no accident. It is the choice of a pool of dynamic talents, trained to international standards and sharing a rigorous work culture.
                    </p>
                </div>
            </div>
            <div class="relative animate-fade-in-right">
                <div class="absolute -inset-4 rounded-[3rem] bg-amber-500/10 blur-2xl"></div>
                <div class="relative rounded-[2rem] border border-white/5 bg-slate-900/50 p-12 backdrop-blur-sm">
                    <div class="space-y-10">
                        <div>
                            <div class="text-5xl font-black text-amber-400">8+ years</div>
                            <div class="text-slate-500 uppercase tracking-widest text-sm font-bold">SAP France Experience</div>
                        </div>
                        <div>
                            <div class="text-5xl font-black text-cyan-400">2024</div>
                            <div class="text-slate-500 uppercase tracking-widest text-sm font-bold">Foundation Year</div>
                        </div>
                        <div>
                            <div class="text-5xl font-black text-amber-400">100%</div>
                            <div class="text-slate-500 uppercase tracking-widest text-sm font-bold">Quality Commitment</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="rounded-[3rem] bg-slate-900/30 border border-white/5 p-12 sm:p-20 mb-24 animate-fade-in-up">
            <div class="max-w-3xl mx-auto text-center">
                <h2 class="text-4xl font-bold text-white mb-10">Our Core Values</h2>
                <div class="grid gap-12 sm:grid-cols-2 text-left">
                    <div class="space-y-4">
                        <div class="text-amber-400 font-black text-xl">Excellence</div>
                        <p class="text-slate-400">We never compromise on the technical and methodological quality of our interventions.</p>
                    </div>
                    <div class="space-y-4">
                        <div class="text-cyan-400 font-black text-xl">Stability</div>
                        <p class="text-slate-400">We build long-term teams to ensure project continuity over time.</p>
                    </div>
                    <div class="space-y-4">
                        <div class="text-cyan-400 font-black text-xl">Transparency</div>
                        <p class="text-slate-400">Clear governance and honest reporting for a lasting relationship of trust.</p>
                    </div>
                    <div class="space-y-4">
                        <div class="text-amber-400 font-black text-xl">Agility</div>
                        <p class="text-slate-400">A flexible model capable of adapting quickly to your changing business priorities.</p>
                    </div>
                </div>
            </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

---
import Layout from "../../../layouts/Layout.astro";
import jobs from "../../../data/jobs.json";

export function getStaticPaths() {
  return jobs.map((job) => ({
    params: { id: job.id },
    props: { job },
  }));
}

const { job } = Astro.props;

// Basic translation mapping for EN
const translations: Record<string, any> = {
    "sap-fi-co": {
        title: "SAP FI-CO Consultant (M/F)",
        description: "We are looking for a passionate SAP FI-CO consultant to support our French clients in their financial process transformation.",
        missions: [
            "Analysis of business needs and writing of functional specifications",
            "Configuration of FI (GL, AP, AR, AA) and CO (OM, PC, PA) modules",
            "Supporting users during testing and acceptance phases",
            "Leading design workshops and training key users",
            "Post-production support and evolutive maintenance"
        ],
        profile: [
            "Engineering degree or master's in finance/IT",
            "Significant experience in SAP FI and/or CO",
            "Knowledge of S/4HANA is a plus",
            "Excellent command of French (oral and written)",
            "Client service-oriented and team spirit"
        ]
    },
    "abap-edi-senior": {
        title: "Senior ABAP / EDI Developer (M/F)",
        description: "Join our technical delivery center to drive complex developments and ensure the integration of our clients' data flows.",
        missions: [
            "Technical design and ABAP Objects development",
            "Implementation of EDI interfaces (IDOC, ALE, PI/PO)",
            "Development of forms (Smartforms, Adobe Forms)",
            "Optimization of program performance",
            "Technological watch on Fiori, UI5, and BTP"
        ],
        profile: [
            "Solid technical background in SAP ABAP",
            "Confirmed experience in EDI integration flows",
            "Ability to mentor junior profiles",
            "Rigor, autonomy, and technical curiosity",
            "Mastery of French is essential"
        ]
    }
};

const tJob = translations[job.id] || job;
---

<Layout title={`${tJob.title} - Careers - NZ IT Services`}>
  <main class="relative overflow-hidden">
    <section class="relative px-6 py-24 sm:px-10 lg:px-14">
      <div class="mx-auto max-w-4xl">
        <a href="/en/careers" class="inline-flex items-center gap-2 text-amber-400 font-bold mb-12 hover:gap-4 transition-all">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Back to offers
        </a>

        <div class="mb-16">
            <div class="flex gap-4 mb-6">
                <span class="inline-flex rounded-full bg-amber-400/10 px-4 py-1 text-xs font-bold text-amber-400">Permanent · {job.location}</span>
                <span class="inline-flex rounded-full bg-cyan-400/10 px-4 py-1 text-xs font-bold text-cyan-400">{job.experience}</span>
            </div>
            <h1 class="text-5xl font-black text-white mb-8 sm:text-6xl">{tJob.title}</h1>
            <p class="text-xl text-slate-400 leading-relaxed">{tJob.description}</p>
        </div>

        <div class="grid gap-12 lg:grid-cols-[1.5fr_1fr]">
            <div class="space-y-12">
                <div class="rounded-[2.5rem] border border-white/5 bg-slate-900/50 p-10">
                    <h2 class="text-2xl font-bold text-white mb-6">Your Missions</h2>
                    <ul class="space-y-4">
                        {tJob.missions.map((mission: string) => (
                            <li class="flex gap-4 text-slate-400 leading-7">
                                <div class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-amber-400"></div>
                                {mission}
                            </li>
                        ))}
                    </ul>
                </div>

                <div class="rounded-[2.5rem] border border-white/5 bg-slate-900/50 p-10">
                    <h2 class="text-2xl font-bold text-white mb-6">Your Profile</h2>
                    <ul class="space-y-4">
                        {tJob.profile.map((item: string) => (
                            <li class="flex gap-4 text-slate-400 leading-7">
                                <div class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-400"></div>
                                {item}
                            </li>
                        ))}
                    </ul>
                </div>
            </div>

            <aside>
                <div class="sticky top-32">
                    <div class="rounded-[2.5rem] border border-white/10 bg-white p-10 text-center shadow-2xl">
                        <h3 class="text-2xl font-black text-slate-950 mb-4">Apply for this position</h3>
                        <p class="text-slate-600 mb-8 text-sm">Ready to take on the challenge? Send us your application in a few clicks.</p>
                        <a href={`/en/contact?subject=Application for ${tJob.title}`} class="block w-full rounded-2xl bg-amber-500 py-5 text-lg font-black text-slate-950 hover:bg-amber-400 transition-all shadow-xl shadow-amber-500/20">
                            Apply Now
                        </a>
                    </div>
                    
                    <div class="mt-8 rounded-[2.5rem] border border-white/5 bg-slate-900/30 p-10">
                        <h4 class="text-white font-bold mb-4 italic">"A structure designed by consultants, for consultants."</h4>
                        <p class="text-slate-500 text-sm">— F. AIT ALI BRAHAM, CEO</p>
                    </div>
                </div>
            </aside>
        </div>
      </div>
    </section>
  </main>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const isEn = lang === 'en';

const labels = {
    firstName: isEn ? "First Name" : "Prénom",
    lastName: isEn ? "Last Name" : "Nom",
    email: isEn ? "Business Email" : "Email Professionnel",
    subject: isEn ? "Subject" : "Objet",
    message: isEn ? "Message" : "Message",
    cv: isEn ? "Attach CV (PDF)" : "Joindre CV (PDF)",
    send: isEn ? "Send Application" : "Envoyer ma candidature",
    placeholderFirstName: isEn ? "John" : "Jean",
    placeholderLastName: isEn ? "Doe" : "Dupont",
    placeholderEmail: isEn ? "john@company.com" : "jean@entreprise.com",
    placeholderSubject: isEn ? "Your project or application" : "Votre projet ou candidature",
    placeholderMessage: isEn ? "Details about your needs..." : "Détaillez votre besoin ici...",
    success: isEn ? "Thank you! Your message has been sent." : "Merci ! Votre message a été envoyé.",
    contactTitle: isEn ? "Let's talk about your projects" : "Parlons de vos projets",
    contactDesc: isEn ? "Whether you want to outsource your SAP developments or strengthen your teams, NZ IT Services brings you a tailor-made solution." : "Que vous souhaitiez externaliser vos développements SAP ou renforcer vos équipes, NZ IT Services vous apporte une solution sur-mesure."
};
---

<Layout title={`${isEn ? 'Contact' : 'Contact'} - NZ IT Services`}>
  <main class="relative overflow-hidden">
    <section class="relative px-6 py-24 sm:px-10 lg:px-14">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-20 lg:grid-cols-2 lg:items-start">
          <div class="animate-fade-in-left">
            <p class="text-sm font-bold uppercase tracking-[0.3em] text-amber-400">CONTACT</p>
            <h1 class="mt-6 text-6xl font-black text-white sm:text-7xl">{labels.contactTitle}</h1>
            <p class="mt-8 text-xl text-slate-400 leading-relaxed max-w-xl">
              {labels.contactDesc}
            </p>

            <div class="mt-16 space-y-12">
              <div class="flex items-center gap-8 group">
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-[1.25rem] border border-white/5 bg-slate-900/50 text-amber-400 transition-colors group-hover:bg-amber-400 group-hover:text-slate-950">
                  <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                  <div class="text-slate-500 text-sm font-bold uppercase tracking-widest mb-1">{isEn ? 'Phone' : 'Téléphone'}</div>
                  <div class="text-white text-2xl font-bold">+33 7 53 90 85 70</div>
                </div>
              </div>
              <div class="flex items-center gap-8 group">
                <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-[1.25rem] border border-white/5 bg-slate-900/50 text-cyan-400 transition-colors group-hover:bg-cyan-400 group-hover:text-slate-950">
                  <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z"/></svg>
                </div>
                <div>
                  <div class="text-slate-500 text-sm font-bold uppercase tracking-widest mb-1">Email</div>
                  <div class="text-white text-2xl font-bold">contact@nz-services.fr</div>
                </div>
              </div>
            </div>
          </div>

          <div class="relative animate-fade-in-right">
            <div class="absolute -inset-4 rounded-[3rem] bg-amber-500/5 blur-3xl"></div>
            <div class="relative rounded-[2.5rem] border border-white/10 bg-slate-900/80 p-10 sm:p-14 backdrop-blur-xl shadow-2xl">
                <form id="contact-form" class="space-y-8">
                    <div class="grid gap-8 sm:grid-cols-2">
                        <div class="space-y-3">
                            <label for="first-name" class="text-sm font-bold uppercase tracking-widest text-slate-500">{labels.firstName}</label>
                            <input type="text" id="first-name" name="first-name" class="w-full rounded-2xl border border-white/5 bg-slate-950/50 px-6 py-4 text-white focus:border-amber-400 focus:outline-none transition-colors" placeholder={labels.placeholderFirstName} required>
                        </div>
                        <div class="space-y-3">
                            <label for="last-name" class="text-sm font-bold uppercase tracking-widest text-slate-500">{labels.lastName}</label>
                            <input type="text" id="last-name" name="last-name" class="w-full rounded-2xl border border-white/5 bg-slate-950/50 px-6 py-4 text-white focus:border-amber-400 focus:outline-none transition-colors" placeholder={labels.placeholderLastName} required>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <label for="email" class="text-sm font-bold uppercase tracking-widest text-slate-500">{labels.email}</label>
                        <input type="email" id="email" name="email" class="w-full rounded-2xl border border-white/5 bg-slate-950/50 px-6 py-4 text-white focus:border-amber-400 focus:outline-none transition-colors" placeholder={labels.placeholderEmail} required>
                    </div>
                    <div class="space-y-3">
                        <label for="subject" class="text-sm font-bold uppercase tracking-widest text-slate-500">{labels.subject}</label>
                        <input type="text" id="subject" name="subject" class="w-full rounded-2xl border border-white/5 bg-slate-950/50 px-6 py-4 text-white focus:border-amber-400 focus:outline-none transition-colors" placeholder={labels.placeholderSubject} required>
                    </div>
                    
                    <div id="cv-field" class="space-y-3 hidden">
                        <label for="cv" class="text-sm font-bold uppercase tracking-widest text-slate-500">{labels.cv}</label>
                        <div class="relative">
                            <input type="file" id="cv" name="cv" accept=".pdf" class="w-full rounded-2xl border border-white/5 bg-slate-950/50 px-6 py-4 text-white focus:border-amber-400 focus:outline-none transition-colors file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-amber-400/10 file:text-amber-400 hover:file:bg-amber-400/20 cursor-pointer">
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label for="message" class="text-sm font-bold uppercase tracking-widest text-slate-500">{labels.message}</label>
                        <textarea id="message" name="message" rows="4" class="w-full rounded-2xl border border-white/5 bg-slate-950/50 px-6 py-4 text-white focus:border-amber-400 focus:outline-none transition-colors" placeholder={labels.placeholderMessage} required></textarea>
                    </div>
                    <button type="submit" class="w-full rounded-2xl bg-amber-500 py-6 text-lg font-black text-slate-950 hover:bg-amber-400 transition-all hover:scale-[1.02] shadow-xl shadow-amber-500/20">
                        {labels.send}
                    </button>
                </form>
                <div id="form-success" class="hidden mt-8 p-6 rounded-2xl bg-green-500/10 border border-green-500/20 text-green-400 text-center font-bold">
                    {labels.success}
                </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    // Handle subject and CV field visibility
    const urlParams = new URLSearchParams(window.location.search);
    const subject = urlParams.get('subject');
    const subjectInput = document.getElementById('subject') as HTMLInputElement;
    const cvField = document.getElementById('cv-field');

    if (subject) {
      if (subjectInput) subjectInput.value = subject;
      if (subject.toLowerCase().includes('candidature') || subject.toLowerCase().includes('application')) {
        cvField?.classList.remove('hidden');
      }
    }

    // Basic form submission simulation
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('form-success');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      form.classList.add('opacity-50', 'pointer-events-none');
      setTimeout(() => {
        form.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      }, 1000);
    });
  </script>
</Layout>

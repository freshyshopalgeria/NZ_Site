---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="Our Services - NZ IT Services">
  <main class="relative overflow-hidden">
    <section class="relative px-6 py-24 sm:px-10 lg:px-14">
      <div class="mx-auto max-w-6xl">
        <div class="mb-20 text-center animate-fade-in-up">
          <p class="text-sm font-bold uppercase tracking-[0.3em] text-amber-400">OUR EXPERTISE</p>
          <h1 class="mt-6 text-6xl font-black text-white sm:text-7xl">End-to-End SAP Solutions</h1>
          <p class="mx-auto mt-6 max-w-3xl text-xl text-slate-400">
            A business-driven approach coupled with technical excellence to transform your Information System into a performance lever.
          </p>
        </div>

        <div class="grid gap-16 lg:grid-cols-2 mb-32">
          <div class="space-y-12">
            <div class="animate-fade-in-left">
                <h2 class="text-4xl font-bold text-white mb-6">Functional Expertise</h2>
                <p class="text-lg text-slate-400 leading-relaxed mb-10">
                    Our consultants intervene on the modules at the heart of the company's operational performance.
                </p>
                <div class="grid gap-8 sm:grid-cols-2">
                    <div class="group p-8 rounded-[2rem] border border-white/5 bg-slate-900/50 hover:border-amber-500/30 transition-all">
                        <div class="text-3xl font-black text-amber-400 mb-4">FI-CO</div>
                        <h3 class="text-white font-bold mb-2">Finance & Controlling</h3>
                        <p class="text-slate-500 text-sm leading-6">Optimization of financial flows, analytical accounting, and performance management.</p>
                    </div>
                    <div class="group p-8 rounded-[2rem] border border-white/5 bg-slate-900/50 hover:border-cyan-500/30 transition-all">
                        <div class="text-3xl font-black text-cyan-400 mb-4">SD-MM</div>
                        <h3 class="text-white font-bold mb-2">Sales & Logistics</h3>
                        <p class="text-slate-500 text-sm leading-6">Management of supply chain, purchasing, and sales distribution.</p>
                    </div>
                </div>
            </div>

            <div class="animate-fade-in-left delay-200">
                <h2 class="text-4xl font-bold text-white mb-6">Technical Expertise</h2>
                <p class="text-lg text-slate-400 leading-relaxed mb-10">
                    We master core technologies to ensure the scalability and openness of your SAP landscape.
                </p>
                <div class="grid gap-8 sm:grid-cols-2">
                    <div class="group p-8 rounded-[2rem] border border-white/5 bg-slate-900/50 hover:border-amber-500/30 transition-all">
                        <div class="text-3xl font-black text-amber-400 mb-4">ABAP</div>
                        <h3 class="text-white font-bold mb-2">Advanced Dev</h3>
                        <p class="text-slate-500 text-sm leading-6">Custom developments, performance optimization, and output management (forms, reports).</p>
                    </div>
                    <div class="group p-8 rounded-[2rem] border border-white/5 bg-slate-900/50 hover:border-cyan-500/30 transition-all">
                        <div class="text-3xl font-black text-cyan-400 mb-4">EDI</div>
                        <h3 class="text-white font-bold mb-2">Integration</h3>
                        <p class="text-slate-500 text-sm leading-6">Inter-system data flows, partner integration, and exchange platforms.</p>
                    </div>
                </div>
            </div>
          </div>

          <div class="relative animate-fade-in-right">
             <div class="sticky top-32">
                <div class="absolute -inset-4 rounded-[3rem] bg-cyan-500/5 blur-3xl"></div>
                <div class="relative rounded-[3rem] border border-white/10 bg-slate-900/80 p-12 backdrop-blur-xl shadow-2xl">
                    <h3 class="text-3xl font-black text-white mb-8">Delivery Model</h3>
                    <p class="text-slate-400 mb-12">A structured process inspired by the standards of major consulting firms.</p>
                    
                    <div class="space-y-10">
                        <div class="flex gap-6">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-amber-400 text-slate-950 font-black text-xl shadow-lg shadow-amber-400/20">1</div>
                            <div>
                                <h4 class="text-xl font-bold text-white mb-2">Scoping & Audit</h4>
                                <p class="text-slate-500 text-sm leading-6">In-depth analysis of existing systems, identifying gaps, and defining the target trajectory (S/4HANA Migration, Move to Cloud).</p>
                            </div>
                        </div>
                        <div class="flex gap-6">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-amber-400 text-slate-950 font-black text-xl shadow-lg shadow-amber-400/20">2</div>
                            <div>
                                <h4 class="text-xl font-bold text-white mb-2">Nearshore Execution</h4>
                                <p class="text-slate-500 text-sm leading-6">Configuration, developments, and unit tests carried out by our dedicated experts in Oran under French governance.</p>
                            </div>
                        </div>
                        <div class="flex gap-6">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-amber-400 text-slate-950 font-black text-xl shadow-lg shadow-amber-400/20">3</div>
                            <div>
                                <h4 class="text-xl font-bold text-white mb-2">Deployment & Run</h4>
                                <p class="text-slate-500 text-sm leading-6">User acceptance testing, production deployment, and post-go-live support to ensure optimal adoption.</p>
                            </div>
                        </div>
                    </div>
                </div>
             </div>
          </div>
        </div>

        <div class="rounded-[4rem] bg-gradient-to-br from-slate-900 to-slate-950 border border-white/5 p-16 sm:p-24 text-center animate-fade-in-up">
            <h2 class="text-5xl font-black text-white mb-12">Why entrust us with your projects?</h2>
            <div class="grid gap-16 md:grid-cols-3 mt-20">
                <div class="space-y-6">
                    <div class="text-amber-400 text-6xl font-black">100%</div>
                    <div class="space-y-2">
                        <p class="text-2xl font-bold text-white">Focus SAP</p>
                        <p class="text-slate-500 leading-relaxed">No dispersion. Exclusive expertise on the SAP ecosystem.</p>
                    </div>
                </div>
                <div class="space-y-6">
                    <div class="text-cyan-400 text-6xl font-black">Near</div>
                    <div class="space-y-2">
                        <p class="text-2xl font-bold text-white">Proximity</p>
                        <p class="text-slate-500 leading-relaxed">Fluid communication, without language or time zone barriers.</p>
                    </div>
                </div>
                <div class="space-y-6">
                    <div class="text-amber-400 text-6xl font-black">TCO</div>
                    <div class="space-y-2">
                        <p class="text-2xl font-bold text-white">Optimized</p>
                        <p class="text-slate-500 leading-relaxed">Exceptional value for money thanks to our structured nearshore model.</p>
                    </div>
                </div>
            </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<main class="relative overflow-hidden bg-slate-950 text-slate-100">
		<div class="pointer-events-none absolute inset-x-0 -top-24 h-96 bg-[radial-gradient(circle_at_top,_rgba(245,158,11,0.18),_transparent_34%),radial-gradient(circle_at_20%_top,_rgba(125,211,252,0.14),_transparent_28%)] animate-parallax"></div>

		<!-- Particules flottantes animées -->
		<div class="pointer-events-none absolute inset-0 overflow-hidden">
			<div class="absolute top-1/4 left-1/4 w-2 h-2 bg-amber-300/20 rounded-full animate-float delay-100"></div>
			<div class="absolute top-1/3 right-1/3 w-1 h-1 bg-cyan-300/30 rounded-full animate-parallax-slow delay-500"></div>
			<div class="absolute bottom-1/3 left-1/3 w-1.5 h-1.5 bg-amber-400/15 rounded-full animate-parallax-fast delay-700"></div>
			<div class="absolute top-2/3 right-1/4 w-1 h-1 bg-cyan-400/25 rounded-full animate-float delay-300"></div>
			<div class="absolute top-1/2 left-1/2 w-0.5 h-0.5 bg-white/30 rounded-full animate-bounce-in delay-1000"></div>
			<div class="absolute bottom-1/4 right-1/4 w-1.5 h-1.5 bg-amber-500/10 rounded-full animate-rotate-in delay-1200"></div>
		</div>

		<section class="relative overflow-hidden px-6 py-20 sm:px-10 lg:px-14">
			<div class="mx-auto max-w-7xl">
				<div class="mb-8 text-slate-400 uppercase tracking-[0.35em] text-sm flex items-center gap-4 animate-fade-in-up">
					<img src="/nz-logo-blanc.png" alt="NZ IT Services Logo" class="h-8 w-auto animate-pulse-glow">
					NZ IT SERVICES
				</div>
				<div class="grid gap-12 lg:grid-cols-[1.4fr_0.95fr] lg:items-end">
					<div class="space-y-8">
						<div class="inline-flex items-center gap-3 rounded-full border border-amber-400/20 bg-amber-400/10 px-4 py-2 text-sm uppercase tracking-[0.35em] text-amber-200 shadow-sm shadow-amber-500/10 animate-fade-in-left delay-200 hover:scale-105 transition-transform duration-300">
							<span class="h-2.5 w-2.5 rounded-full bg-amber-300 animate-pulse"></span>
							PARTENAIRE IT
						</div>
						<h1 class="text-5xl font-black tracking-tight text-white sm:text-6xl xl:text-7xl animate-fade-in-up delay-300">
							<span class="block">VOTRE PARTENAIRE IT</span>
							<span class="mt-4 block text-amber-300 text-3xl font-semibold sm:text-4xl animate-fade-in-up delay-500">SAP DELIVERY CENTER · NEARSHORE FR TIMEZONE</span>
						</h1>
						<p class="max-w-3xl text-lg leading-8 text-slate-300 sm:text-xl animate-fade-in-up delay-700">
							Paris - France · Oran - Algérie
						</p>
					</div>

					<div class="relative overflow-hidden rounded-[2rem] border border-slate-700 bg-slate-900/95 p-8 shadow-[0_40px_120px_-60px_rgba(15,23,42,0.9)] animate-fade-in-right delay-500 hover:shadow-[0_50px_150px_-70px_rgba(15,23,42,0.95)] transition-all duration-500 group">
						<div class="absolute right-0 top-0 h-28 w-28 translate-x-1/4 -translate-y-1/4 rounded-full bg-amber-500/10 blur-3xl group-hover:bg-amber-500/20 transition-colors duration-500"></div>
						<div class="absolute left-0 bottom-0 h-24 w-24 -translate-x-1/3 rounded-full bg-cyan-400/10 blur-3xl group-hover:bg-cyan-400/20 transition-colors duration-500"></div>
						<p class="text-sm uppercase tracking-[0.3em] text-slate-400 animate-fade-in-up delay-600">Notre approche</p>
						<h2 class="mt-4 text-3xl font-semibold text-white animate-fade-in-up delay-700">Nearshore structuré</h2>
						<p class="mt-4 text-slate-300 leading-7 animate-fade-in-up delay-800">
							Proximité, stabilité et delivery de qualité avec un modèle organisationnel inspiré des standards des ESN françaises.
						</p>
						<div class="mt-8 grid gap-4">
							<div class="flex items-start gap-4 rounded-3xl border border-slate-800 bg-slate-950/70 p-4 animate-fade-in-up delay-900 hover:bg-slate-950/90 hover:border-amber-500/30 transition-all duration-300 group/item">
								<div class="mt-1 flex h-10 w-10 items-center justify-center rounded-2xl bg-amber-300/15 text-amber-200 group-hover/item:bg-amber-300/25 transition-colors duration-300">
									<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>
								</div>
								<div>
									<div class="text-white font-semibold group-hover/item:text-amber-200 transition-colors duration-300">SAP deliveries</div>
									<p class="text-slate-400 mt-1 text-sm">Opérations alignées avec vos priorités métier.</p>
								</div>
							</div>
							<div class="flex items-start gap-4 rounded-3xl border border-slate-800 bg-slate-950/70 p-4 animate-fade-in-up delay-1000 hover:bg-slate-950/90 hover:border-cyan-500/30 transition-all duration-300 group/item">
								<div class="mt-1 flex h-10 w-10 items-center justify-center rounded-2xl bg-cyan-300/15 text-cyan-200 group-hover/item:bg-cyan-300/25 transition-colors duration-300">
									<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20c4.418 0 8-3.582 8-8s-3.582-8-8-8-8 3.582-8 8 3.582 8 8 8z"></path><path d="M9 12l2 2 4-4"></path></svg>
								</div>
								<div>
									<div class="text-white font-semibold group-hover/item:text-cyan-200 transition-colors duration-300">Qualité garantie</div>
									<p class="text-slate-400 mt-1 text-sm">Processus cadrés et équipes stables dédiées à votre réussite.</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="border-t border-slate-800 bg-slate-900/95 px-6 py-16 sm:px-10 visual-separator">
			<div class="mx-auto max-w-6xl">
				<div class="mb-12 text-center animate-fade-in-up section-indicator">
					<p class="text-sm uppercase tracking-[0.35em] text-amber-300">À PROPOS</p>
					<h2 class="mt-4 text-4xl font-bold text-white">NZ IT Services en quelques points</h2>
				</div>
				<div class="grid gap-8 lg:grid-cols-2">
					<div class="space-y-6 rounded-3xl border border-slate-800 bg-slate-950 p-10 text-slate-100 shadow-xl shadow-slate-950/30 animate-fade-in-left hover:shadow-2xl hover:shadow-slate-950/50 transition-all duration-500">
						<p class="text-slate-300 leading-8 reading-guide">
							NZ IT Services est une structure récemment créée, fondée par un consultant SAP franco-algérien disposant de plus de 8 ans d'expérience sur des projets SAP en France.
						</p>
						<p class="text-slate-300 leading-8 reading-guide">
							Construite à partir d’une expérience terrain au sein d’environnements exigeants, la démarche NZ repose sur des standards de delivery inspirés des ESN françaises.
						</p>
					</div>
					<div class="space-y-4">
						<div class="rounded-3xl border border-slate-800 bg-slate-900 p-8 shadow-xl shadow-slate-950/30 animate-fade-in-right delay-200 hover:shadow-2xl hover:shadow-slate-950/50 hover:border-amber-500/20 transition-all duration-500">
							<p class="text-sm uppercase tracking-[0.35em] text-amber-300">Bureaux</p>
							<h3 class="mt-4 text-2xl font-semibold text-white">Oran & Paris</h3>
							<p class="mt-3 text-slate-400 leading-7">Des équipes proches du fuseau français, ancrées dans un environnement de delivery stable.</p>
						</div>
						<div class="rounded-3xl border border-slate-800 bg-slate-900 p-8 shadow-xl shadow-slate-950/30 animate-fade-in-right delay-300 hover:shadow-2xl hover:shadow-slate-950/50 hover:border-cyan-500/20 transition-all duration-500">
							<p class="text-sm uppercase tracking-[0.35em] text-amber-300">Valeur</p>
							<h3 class="mt-4 text-2xl font-semibold text-white">Confiance & exigence</h3>
							<p class="mt-3 text-slate-400 leading-7">Un cadre professionnel pensé pour durer, avec transparence et exigence.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-slate-950 px-6 py-16 sm:px-10 visual-separator">
			<div class="mx-auto max-w-6xl">
				<div class="mb-12 text-center animate-fade-in-up section-indicator">
					<p class="text-sm uppercase tracking-[0.35em] text-amber-300">Expertise SAP</p>
					<h2 class="mt-4 text-4xl font-bold text-white">Modules clés</h2>
				</div>
				<div class="grid gap-6 md:grid-cols-4">
					<div class="rounded-3xl border border-slate-800 bg-slate-900 p-8 text-center text-slate-100 shadow-xl shadow-slate-950/40 animate-bounce-in delay-200 hover:shadow-2xl hover:shadow-slate-950/60 hover:border-amber-500/30 hover:scale-105 transition-all duration-500 animate-card-hover">
						<div class="text-3xl font-semibold text-amber-300 animate-glow-pulse">FI-CO</div>
						<p class="mt-4 text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-400">Finance & Contrôle de gestion</p>
					</div>
					<div class="rounded-3xl border border-slate-800 bg-slate-900 p-8 text-center text-slate-100 shadow-xl shadow-slate-950/40 animate-rotate-in delay-300 hover:shadow-2xl hover:shadow-slate-950/60 hover:border-cyan-500/30 hover:scale-105 transition-all duration-500 animate-card-hover">
						<div class="text-3xl font-semibold text-cyan-300 animate-glow-pulse">SD-MM</div>
						<p class="mt-4 text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-500">Vente, distribution et logistique</p>
					</div>
					<div class="rounded-3xl border border-slate-800 bg-slate-900 p-8 text-center text-slate-100 shadow-xl shadow-slate-950/40 animate-flip-in delay-500 hover:shadow-2xl hover:shadow-slate-950/60 hover:border-amber-500/30 hover:scale-105 transition-all duration-500 animate-card-hover">
						<div class="text-3xl font-semibold text-amber-300 animate-glow-pulse">ABAP</div>
						<p class="mt-4 text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-700">Développement SAP</p>
					</div>
					<div class="rounded-3xl border border-slate-800 bg-slate-900 p-8 text-center text-slate-100 shadow-xl shadow-slate-950/40 animate-slide-in-up delay-700 hover:shadow-2xl hover:shadow-slate-950/60 hover:border-cyan-500/30 hover:scale-105 transition-all duration-500 animate-card-hover">
						<div class="text-3xl font-semibold text-cyan-300 animate-glow-pulse">EDI</div>
						<p class="mt-4 text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-900">Échanges de données inter-systèmes</p>
					</div>
				</div>
			</div>
		</section>

		<section class="border-t border-slate-800 bg-slate-900/95 px-6 py-16 sm:px-10 visual-separator">
			<div class="mx-auto max-w-6xl">
				<div class="mb-12 text-center section-indicator">
					<p class="text-sm uppercase tracking-[0.35em] text-amber-300">Processus</p>
					<h2 class="mt-4 text-4xl font-bold text-white">Notre démarche opérationnelle</h2>
				</div>
				<div class="grid gap-8 lg:grid-cols-3">
					<div class="rounded-3xl border border-slate-800 bg-slate-950 p-8 text-center shadow-2xl shadow-slate-950/40 animate-slide-in-up delay-200 animate-card-hover">
						<div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-amber-300/10 text-amber-300 animate-bounce-in delay-300">
							<svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"/></svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-4 animate-fade-in-up delay-400">Sourcing</h3>
						<p class="text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-500">NZ source des profils qualifiés selon les besoins définis.</p>
					</div>
					<div class="rounded-3xl border border-slate-800 bg-slate-950 p-8 text-center shadow-2xl shadow-slate-950/40 animate-bounce-in delay-400 animate-card-hover">
						<div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-cyan-300/10 text-cyan-300 animate-rotate-in delay-500">
							<svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"></path><path d="M21 12c-1 0-3-1-3-3s2-3 3-3 3 1 3 3-2 3-3 3"></path><path d="M3 12c1 0 3-1 3-3s-2-3-3-3-3 1-3 3 2 3 3 3"></path></svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-4 animate-fade-in-up delay-600">Validation</h3>
						<p class="text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-700">Présentation et validation des consultants avant intégration.</p>
					</div>
					<div class="rounded-3xl border border-slate-800 bg-slate-950 p-8 text-center shadow-2xl shadow-slate-950/40 animate-flip-in delay-600 animate-card-hover">
						<div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-700 text-white animate-slide-in-up delay-700">
							<svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13,2 13,9 20,9"></polyline></svg>
						</div>
						<h3 class="text-xl font-semibold text-white mb-4 animate-fade-in-up delay-800">Intégration</h3>
						<p class="text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-900">Intégration rapide au sein des équipes, delivery 100% en présentiel.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-slate-950 px-6 py-16 sm:px-10 visual-separator">
			<div class="mx-auto max-w-6xl">
				<div class="mb-12 text-center section-indicator">
					<p class="text-sm uppercase tracking-[0.35em] text-amber-300">Localisation</p>
					<h2 class="mt-4 text-4xl font-bold text-white">Présence internationale</h2>
				</div>
				<div class="relative overflow-hidden rounded-3xl border border-slate-800 bg-slate-900 p-8 shadow-xl shadow-slate-950/40">
					<div class="relative h-64 w-full">
						<svg viewBox="0 0 800 400" class="h-full w-full">
							<defs>
								<pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
									<path d="M 20 0 L 0 0 0 20" fill="none" stroke="#374151" stroke-width="0.5"/>
								</pattern>
							</defs>
							<rect width="800" height="400" fill="url(#grid)"/>
							<!-- Simplified world map outline -->
							<path d="M100,150 Q150,100 200,120 Q250,140 300,130 Q350,120 400,140 Q450,160 500,150 Q550,140 600,160 Q650,180 700,170" fill="none" stroke="#64748b" stroke-width="2"/>
							<!-- Paris marker -->
							<circle cx="250" cy="120" r="8" fill="#f59e0b"/>
							<text x="270" y="125" fill="#f59e0b" font-size="12" font-weight="bold">Paris</text>
							<!-- Oran marker -->
							<circle cx="450" cy="180" r="8" fill="#06b6d4"/>
							<text x="470" y="185" fill="#06b6d4" font-size="12" font-weight="bold">Oran</text>
						</svg>
					</div>
					<div class="mt-6 grid gap-4 md:grid-cols-2">
						<div class="flex items-center gap-4 rounded-3xl border border-slate-800 bg-slate-950/70 p-4">
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-amber-300/15 text-amber-300">
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
							</div>
							<div>
								<div class="text-white font-semibold">Paris - France</div>
								<p class="text-slate-400 text-sm">Siège européen et relations clients</p>
							</div>
						</div>
						<div class="flex items-center gap-4 rounded-3xl border border-slate-800 bg-slate-950/70 p-4">
							<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-cyan-300/15 text-cyan-300">
								<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
							</div>
							<div>
								<div class="text-white font-semibold">Oran - Algérie</div>
								<p class="text-slate-400 text-sm">Centre de delivery nearshore</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="border-t border-slate-800 bg-slate-900/95 px-6 py-16 sm:px-10 visual-separator">
			<div class="mx-auto max-w-6xl">
				<div class="mb-10 text-center section-indicator">
					<p class="text-sm uppercase tracking-[0.35em] text-amber-300">Valeurs</p>
					<h2 class="mt-4 text-4xl font-bold text-white">Stabilité, organisation, expertise, confiance</h2>
				</div>
				<div class="grid gap-6 md:grid-cols-4">
					<div class="rounded-3xl border border-slate-800 bg-slate-950 p-8 text-center shadow-xl shadow-slate-950/30 animate-bounce-in delay-200 animate-card-hover">
						<div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-300/10 text-amber-300 animate-rotate-in delay-300">
							<svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
						</div>
						<h3 class="text-xl font-semibold text-white animate-fade-in-up delay-400">Stabilité</h3>
						<p class="mt-4 text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-500">Des missions stables et durables, pensées comme des partenariats de carrière.</p>
					</div>
					<div class="rounded-3xl border border-slate-800 bg-slate-950 p-8 text-center shadow-xl shadow-slate-950/30 animate-rotate-in delay-300 animate-card-hover">
						<div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-cyan-300/10 text-cyan-200 animate-flip-in delay-400">
							<svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y="9" x2="9" y2="15"/></svg>
						</div>
						<h3 class="text-xl font-semibold text-white animate-fade-in-up delay-500">Organisation</h3>
						<p class="mt-4 text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-600">Un modèle inspiré des standards ESN françaises, avec des processus clairs.</p>
					</div>
					<div class="rounded-3xl border border-slate-800 bg-slate-950 p-8 text-center shadow-xl shadow-slate-950/30 animate-flip-in delay-500 animate-card-hover">
						<div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-700 text-white animate-slide-in-up delay-600">
							<svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
						</div>
						<h3 class="text-xl font-semibold text-white animate-fade-in-up delay-700">Expertise</h3>
						<p class="mt-4 text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-800">Des consultants SAP expérimentés sur des projets français et internationaux.</p>
					</div>
					<div class="rounded-3xl border border-slate-800 bg-slate-950 p-8 text-center shadow-xl shadow-slate-950/30 animate-slide-in-up delay-700 animate-card-hover">
						<div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-300/10 text-amber-300 animate-bounce-in delay-800">
							<svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
						</div>
						<h3 class="text-xl font-semibold text-white animate-fade-in-up delay-900">Confiance</h3>
						<p class="mt-4 text-slate-400 leading-7 improved-contrast animate-fade-in-up delay-1000">Une relation humaine, transparente et tournée vers la réussite client.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="border-t border-slate-800 bg-slate-900/95 px-6 py-16 sm:px-10 visual-separator">
			<div class="mx-auto max-w-6xl">
				<div class="mb-12 text-center section-indicator">
					<p class="text-sm uppercase tracking-[0.35em] text-amber-300">Fondateur</p>
					<h2 class="mt-4 text-4xl font-bold text-white">Vision & Parcours</h2>
				</div>
				<div class="grid gap-8 lg:grid-cols-2">
					<div class="space-y-6 rounded-3xl border border-slate-800 bg-slate-950 p-10 text-slate-100 shadow-xl shadow-slate-950/30">
